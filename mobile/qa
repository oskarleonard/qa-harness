#!/bin/bash
# sim-qa engine front door (harness-resident — see repo README).
# Always invoked through a PROJECT's scripts/sim-qa/qa shim, which exports
# QA_PROJECT_QA_DIR = the project's qa dir. That dir layers everything
# project-specific over this engine:
#   target.py      pinned sim/port/bundle/mode        (committed, required)
#   target.local   per-machine sim UDID pin           (gitignored, auto-written)
#   product/       ground truth + design map + rails  (optional)
#   ext/           project-specific subcommands       (optional)
#   runs/          per-run output                     (gitignored)
set -euo pipefail
H="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMON="$(cd "$H/.." && pwd)/common"

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then shift; fi

if [ "$cmd" = "help" ] || [ "$cmd" = "--help" ] || [ "$cmd" = "-h" ]; then
  cat <<'EOF'
sim-qa — AI eyes & hands on an iOS simulator (pin: the project's target.py)

Engine lives in qa-harness/mobile; run it via your project's scripts/sim-qa/qa
shim. Project-specific layers next to the shim: target.py (pin) · product/
(ground truth, Figma map, rails) · ext/ (extra commands) · runs/ (output).

Metro / app lifecycle:
  qa doctor             first-time machine check — every FAIL prints its fix
  qa serve              take over Metro on the tester port (owned + logged)
  qa health             metro up? backend up? app vs launcher? idb companion?
  qa status             what holds the port, tester pid, log sizes
  qa recover            reconnect app; restart Metro if down; respawn idb companion
  qa reload             cold-restart the app (LAST-resort recovery)
  qa logs [N]           last N lines of owned Metro log (default 40)
  qa crashes [N]        crash-pattern hits from the OS log stream (default 20)
  qa stop               kill tester Metro + crash stream (this port only)

Run bookkeeping + eyes & hands:
  qa init --scope S [--driver wake|goal] [--label L]   start a run (journal/findings)
  qa shot <label>       screenshot into the current run
  qa tree               dump labelled a11y elements (what's tappable)
  qa tap --label "AX" [--role Button] [--force] | --tab <name> | --frac fx,fy
                        (--role disambiguates collisions; refuses off-viewport targets)
  qa type <text> [--label L] [--role R] [--clear] [--enter]   type into a field
  qa scroll [down|up] [--amount 0.35]   scroll native lists (NOT RNGH gestures)
  qa note <text>        append a finding to the current run
  qa act <text>         append a line to actions.log
  qa find <label>       locate an element without tapping
  qa companion [ensure] idb companion check / respawn
  qa target [--udid|--port|--bundle|--mode|--window]   print pinned config values

PR evidence (hosts images OFF the PR branch — see RUNBOOK "PR evidence"):
  qa publish <img> --feature S [--name F] [--caption C] [--width N]
                        host a QA image on the hidden qa-assets store ref (no branch, no banner)

Ground truth (delegated to the project's product/qa_api.py when present):
  qa check              assert the project's invariant registry (exit 1 on fail)
  qa snapshot --out f   snapshot state before a risky action
  qa diff f [--expect-new N]   delta probes vs a snapshot

Anything else resolves against the project's ext/ dir (e.g. an autoplay layer).
Modes: set per project in target.py (e.g. LISK_QA_MODE=mock|staging for lisk).
EOF
  exit 0
fi

PROJ="${QA_PROJECT_QA_DIR:-}"
if [ -z "$PROJ" ] || [ ! -f "$PROJ/target.py" ]; then
  echo "qa: QA_PROJECT_QA_DIR not set or no target.py in it — run via your project's scripts/sim-qa/qa shim" >&2
  exit 1
fi
export QA_PROJECT_QA_DIR="$PROJ"

case "$cmd" in
  serve|recover|reload|health|doctor|status|stop)
    exec python3 "$H/core/devserver.py" "$cmd" "$@" ;;
  logs)
    exec python3 "$H/core/devserver.py" metrolog "${1:-40}" ;;
  crashes)
    exec python3 "$H/core/devserver.py" crashes "${1:-20}" ;;
  init|shot|tree|tap|type|scroll|note|act)
    exec python3 "$H/core/qa.py" "$cmd" "$@" ;;
  publish)
    exec python3 "$COMMON/publish.py" "$@" ;;
  check|snapshot|diff)
    if [ -f "$PROJ/product/qa_api.py" ]; then
      exec python3 "$PROJ/product/qa_api.py" "$cmd" "$@"
    fi
    echo "qa $cmd: no ground-truth layer in this project (no product/qa_api.py) — nothing to assert"
    exit 0 ;;
  find)
    exec python3 "$H/core/idb_ui.py" find "$@" ;;
  companion)
    exec python3 "$H/core/idb_ui.py" companion "$@" ;;
  target)
    exec python3 "$PROJ/target.py" "$@" ;;
  *)
    for cand in "$PROJ/ext/$cmd" "$PROJ/ext/$cmd.py" "$PROJ/ext/$cmd.sh"; do
      [ -f "$cand" ] || continue
      case "$cand" in
        *.py) exec python3 "$cand" "$@" ;;
        *.sh) exec bash "$cand" "$@" ;;
        *)    exec "$cand" "$@" ;;
      esac
    done
    echo "qa: unknown command '$cmd' — run 'qa help' (project commands live in ext/)" >&2
    exit 1 ;;
esac
